@"
# Environment variables
.env
.env.local
.env.*.local
.env.production

# Only ignore node_modules inside frontend, not frontend itself
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.next/

# Only ignore Python cache, not backend itself
backend/__pycache__/
backend/.Python
backend/venv/
backend/env/
backend/*.egg-info/
backend/dist/
backend/build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
"@ | Out-File -Encoding UTF8 .gitignore